---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

import "@fontsource-variable/sora";

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Portafolio personal de Jean Tigreros - Desarrollador web y estudiante de ingeniería de sistemas" />
    <meta name="theme-color" content="#17181c" />
    <link rel="icon" type="image/svg+xml" href={import.meta.env.BASE_URL + '/favicon.ico'} />
    <title>{title}</title>
  </head>
  <body class="text-white">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
<style is:global>
  :root {
    color-scheme: dark;
  }
  html {
    background-color: #17181c;
    font-family: "Sora Variable", system-ui, sans-serif;
    scroll-behavior: smooth;
    scroll-padding-top: 5rem;
  }
  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    margin: 0;
  }
  * {
    box-sizing: border-box;
  }
  ::selection {
    background-color: #a855f7;
    color: white;
  }
  ::-webkit-scrollbar {
    width: 8px;
  }
  ::-webkit-scrollbar-track {
    background: #17181c;
  }
  ::-webkit-scrollbar-thumb {
    background: #313234;
    border-radius: 4px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #4a4b4e;
  }
</style>
