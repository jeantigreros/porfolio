---
interface Props {
    title: string;
}
const { title } = Astro.props;
---
<div class="max-w-6xl mx-auto px-4 mt-16 mb-10">
  <h2 class="text-3xl md:text-5xl font-extrabold text-white">{title}</h2>
  <div class="h-1 w-16 md:w-24 bg-gradient-to-r from-purple-500 via-pink-500 to-yellow-500 rounded-full mt-4"></div>
</div>
