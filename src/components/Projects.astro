---
import { PROJECTS } from "../const"
import SectionDivider from "./SectionDivider.astro"

const projects = PROJECTS.filter(p => !p.hidden).reverse()
---
<section id="projects">
  <SectionDivider title="Proyectos" />
  <div class="grid gap-6 px-4 max-w-6xl mx-auto grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
    {projects.map((project, i) => {
      const num = String(projects.length - i).padStart(2, "0")
      return (
        <article class="group relative bg-[#25262b] rounded-3xl border border-[#313234] hover:border-gray-600 transition-all duration-300 overflow-hidden flex flex-col">
          <a href={project.link} target="_blank" rel="nofollow noopener noreferrer" class="block overflow-hidden">
            <span class="absolute top-4 left-4 z-10 text-2xl font-bold text-white/80 pointer-events-none">#{num}</span>
            <img
              class="w-full aspect-video object-cover transition-transform duration-500 group-hover:scale-105"
              src={import.meta.env.BASE_URL + `/projects/${num}.webp`}
              alt={`Captura del proyecto ${project.title}`}
              loading="lazy"
            />
          </a>
          <div class="p-5 flex flex-col flex-1">
            <h2 class="text-xl font-bold text-orange-600">
              <a href={project.link} target="_blank" rel="nofollow noopener noreferrer" class="hover:text-orange-300 transition">
                {project.title}
              </a>
            </h2>
            <p class="mt-3 mb-4 text-sm text-gray-300 leading-relaxed">{project.description}</p>
            <ul class="flex flex-wrap gap-2 mt-auto">
              {project.tech.map(tech => (
                <li class="text-xs font-medium text-blue-600 bg-blue-200/90 px-2.5 py-1 rounded-full">{tech}</li>
              ))}
            </ul>
            <div class="flex flex-wrap gap-2 mt-4">
              {project.code && (
                <a href={`https://github.com/jeantigreros/${project.slug}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 px-3 py-2 text-xs font-semibold text-black bg-white rounded-lg hover:bg-gray-200 transition">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
                  Código
                </a>
              )}
              {project.demo && (
                <a href={project.link} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 px-3 py-2 text-xs font-semibold text-yellow-700 bg-yellow-100 rounded-lg hover:bg-yellow-200 transition">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418"/></svg>
                  Demo
                </a>
              )}
            </div>
          </div>
        </article>
      )
    })}
  </div>
</section>
