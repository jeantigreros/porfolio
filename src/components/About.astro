---
import Card from "./Card.astro";
import SectionDivider from "./SectionDivider.astro";
import AstroIcon from "./icons/Astro.astro";
import NextjsIcon from "./icons/Nextjs.astro";
import ReactIcon from "./icons/React.astro";
import TailwindIcon from "./icons/Tailwind.astro";
import CssIcon from "./icons/Css.astro";
import HtmlIcon from "./icons/Html.astro";
import JavascriptIcon from "./icons/Javascript.astro";
import TypescriptIcon from "./icons/Typescript.astro";
import PythonIcon from "./icons/Python.astro";
import NodeIcon from "./icons/Node.astro";
import LinuxIcon from "./icons/Linux.astro";
import GitIcon from "./icons/Git.astro";
import SqlIcon from "./icons/Sql.astro";
import PandasIcon from "./icons/Pandas.astro";
---

<section id="about">
  <SectionDivider title="Sobre mí" />
  <div class="[background:radial-gradient(circle_at_70%_40%,rgb(46,46,47),transparent_450px),radial-gradient(circle_at_25%_65%,rgb(46,46,47),transparent_450px)]">
    <Card>
      <div class="xl:col-span-2 xl:row-span-2 bg-[#25262b] rounded-3xl p-6 md:p-8 border border-[#313234] hover:border-gray-600 transition-all duration-300">
        <h2 class="text-2xl md:text-3xl text-[#9db2bf] font-bold">Jean Carlos Tigreros</h2>
        <p class="text-base md:text-xl leading-relaxed mt-4 text-gray-200">
          Hola! tengo 21 años, actualmente estoy cursando una ingeniería en la
          Universidad Nacional Abierta y a Distancia, en Palmira, Colombia 🇨🇴,
          soy desarrollador web freelancer, mi enfoque está dirigido al
          desarrollo de soluciones de software, desarrollo de páginas web, entre
          otros. Desde pequeño siempre me ha interesado el software, y con el
          tiempo se ha convertido en una pasión 😊
        </p>
        <p class="text-base md:text-xl leading-relaxed mt-4 text-gray-200">
          Dale un vistazo a mis redes sociales!
        </p>
        <div class="flex gap-4 mt-3">
          <a class="underline text-blue-400 hover:text-blue-300 transition" href="https://github.com/jeantigreros" target="_blank">Github</a>
          <a class="underline text-blue-400 hover:text-blue-300 transition" href="https://x.com/nekro24" target="_blank">X</a>
        </div>
      </div>

      <div class="xl:col-span-1 xl:row-span-3 bg-[#25262b] rounded-3xl p-6 md:p-8 border border-[#313234] hover:border-gray-600 transition-all duration-300">
        <h2 class="text-2xl md:text-3xl text-[#9db2bf] font-bold">Habilidades</h2>
        <p class="text-base md:text-xl leading-relaxed mt-4 text-gray-200">Tecnologías con las que trabajo:</p>
        <div class="skills-grid flex flex-wrap gap-3 justify-center pt-6 [&>*]:bg-slate-800 [&>*]:rounded-xl [&>*]:border [&>*]:border-[#313234] [&>*]:p-3 md:[&>*]:p-5 [&>*]:text-center [&>*]:min-w-[80px]">
          <AstroIcon />
          <NextjsIcon />
          <ReactIcon />
          <CssIcon />
          <JavascriptIcon />
          <TypescriptIcon />
          <HtmlIcon />
          <TailwindIcon />
          <PythonIcon />
          <SqlIcon />
          <PandasIcon />
          <NodeIcon />
          <LinuxIcon />
          <GitIcon />
        </div>
      </div>

      <div class="xl:col-span-1 xl:row-span-1 bg-[#25262b] rounded-3xl p-6 md:p-8 border border-[#313234] hover:border-gray-600 transition-all duration-300">
        <h2 class="text-2xl md:text-3xl text-[#9db2bf] font-bold">Aficiones</h2>
        <p class="text-base md:text-xl leading-relaxed mt-4 text-gray-200">
          Fuera del desarrollo: 🎮 <span class="text-[#9db2bf] font-bold">Videojuegos</span>,
          🏛️ <span class="text-[#9db2bf] font-bold">Filosofía</span>,
          📷 <span class="text-[#9db2bf] font-bold">Fotografía</span>,
          💪 <span class="text-[#9db2bf] font-bold">Ejercicio</span>
        </p>
      </div>

      <div class="xl:col-span-1 xl:row-span-1 bg-[#25262b] rounded-3xl border border-[#313234] hover:border-gray-600 transition-all duration-300 flex flex-col items-center justify-center p-6">
        <span class="text-4xl md:text-5xl text-white font-light" id="time">0:00 PM</span>
        <p class="text-xl md:text-2xl text-gray-400 mt-2">Colombia 🇨🇴</p>
      </div>
    </Card>
  </div>
</section>

<style>
  .skills-grid :global(svg) {
    width: 2.5rem;
    height: 2.5rem;
    padding-top: 0;
  }
</style>

<script>
  (function() {
    var el = document.querySelector("#time");
    if (el) {
      var formatter = new Intl.DateTimeFormat([], { timeZone: 'America/Bogota', hour: 'numeric', minute: 'numeric' } as Intl.DateTimeFormatOptions);
      el.textContent = formatter.format(new Date());
      setInterval(function() { if (el) el.textContent = formatter.format(new Date()); }, 1000);
    }
  })();
</script>
